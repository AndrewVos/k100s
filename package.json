{
  "name": "k100s",
  "version": "0.1.3",
  "description": "A Kubernetes desktop browser for clusters, namespaces, and pods.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite --host 127.0.0.1",
    "build": "tauri build",
    "build:web": "vite build",
    "dist:mac": "tauri build",
    "cask:update": "bun scripts/update-homebrew-cask.mjs",
    "cask:check": "ruby -c Casks/k100s.rb",
    "release:version": "bun scripts/release-version.mjs",
    "release:patch": "bun scripts/release-version.mjs patch",
    "release:minor": "bun scripts/release-version.mjs minor",
    "release:major": "bun scripts/release-version.mjs major",
    "demo:cluster": "scripts/demo-cluster.sh up",
    "demo:cluster:down": "scripts/demo-cluster.sh down",
    "demo:cluster:reset": "scripts/demo-cluster.sh reset",
    "demo:cluster:status": "scripts/demo-cluster.sh status",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "@headlessui/react": "^2.2.10",
    "@tailwindcss/vite": "^4.1.7",
    "@tauri-apps/api": "^2.11.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "tailwindcss": "^4.1.7",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1"
  }
}
